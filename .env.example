# ═══════════════════════════════════════════════════════════════════════════════
# IB MARKETPLACE — Environment Variables v4.0
# Copy to .env.local and fill in all values before running
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
CORS_ORIGINS=http://localhost:3000

# ── Database (PostgreSQL + PostGIS) ──────────────────────────────────────────
DATABASE_URL=postgresql://ib_user:ibsecret2026@localhost:5432/ib_marketplace
POSTGRES_PASSWORD=ibsecret2026

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redissecret2026
REDIS_URL=redis://:redissecret2026@localhost:6379

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://ib_rabbit:rabbitsecret2026@localhost:5672
RABBITMQ_PASSWORD=rabbitsecret2026

# ── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Use strong random strings in production (minimum 64 chars)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_USE_DIFFERENT_64_CHAR_RANDOM_STRING

# ── Storage (MinIO / AWS S3) ──────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=ibminio
MINIO_ROOT_PASSWORD=miniosecret2026
MINIO_BUCKET=ib-marketplace
MINIO_USE_SSL=false

# For production AWS S3:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1
# AWS_S3_BUCKET=ib-marketplace-prod

# ── Geocoding ─────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
HERE_MAPS_API_KEY=your_here_maps_api_key_here

# ── Mapbox (Frontend) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Postal verification (Lob.com) ────────────────────────────────────────────
LOB_API_KEY=your_lob_api_key_here
LOB_BASE_URL=https://api.lob.com/v1

# ── KYB Providers ────────────────────────────────────────────────────────────
CREDITSAFE_USERNAME=your_creditsafe_username
CREDITSAFE_PASSWORD=your_creditsafe_password
CREDITSAFE_BASE_URL=https://connect.creditsafe.com/v1

COMPANIES_HOUSE_API_KEY=your_companies_house_api_key
COMPANIES_HOUSE_BASE_URL=https://api.company-information.service.gov.uk

# ── Identity Verification (Onfido) ────────────────────────────────────────────
ONFIDO_API_TOKEN=your_onfido_api_token
ONFIDO_REGION=EU

# ── Sanctions Screening (ComplyAdvantage) ─────────────────────────────────────
COMPLY_ADVANTAGE_API_KEY=your_comply_advantage_key
COMPLY_ADVANTAGE_BASE_URL=https://api.complyadvantage.com

# ── Payments (EU) — Mangopay ──────────────────────────────────────────────────
MANGOPAY_CLIENT_ID=your_mangopay_client_id
MANGOPAY_API_KEY=your_mangopay_api_key
MANGOPAY_BASE_URL=https://api.sandbox.mangopay.com

# ── Payments (UK + Global) — Stripe ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ── FX (Wise) ─────────────────────────────────────────────────────────────────
WISE_API_KEY=your_wise_api_key
WISE_PROFILE_ID=your_wise_profile_id
WISE_BASE_URL=https://api.sandbox.transferwise.tech

# ── VAT Engine (Taxamo/Vertex) ────────────────────────────────────────────────
TAXAMO_API_KEY=your_taxamo_private_token
TAXAMO_BASE_URL=https://api.taxamo.com

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_resend_api_key
EMAIL_FROM=noreply@ibmarketplace.com
EMAIL_FROM_NAME=IB Marketplace

# ── EU Public Procurement (TED eSender) ──────────────────────────────────────
TED_SENDER_ID=your_ted_sender_id
TED_SENDER_SECRET=your_ted_sender_secret
TED_BASE_URL=https://enotices2.ted.europa.eu/esenders/api

# ── UK Public Procurement (Find a Tender) ────────────────────────────────────
FTS_API_KEY=your_fts_api_key
FTS_BASE_URL=https://www.find-tender.service.gov.uk/api

# ── Invest Business integration (Phase 4) ────────────────────────────────────
IB_INTEGRATION_ENABLED=false
IB_API_URL=https://api.investbusiness.com
IB_API_KEY=your_ib_integration_api_key
IB_SHARED_SECRET=your_ib_shared_secret
IB_SCHEMA_VERSION=v1

# ── Monitoring ────────────────────────────────────────────────────────────────
DATADOG_API_KEY=your_datadog_api_key
SENTRY_DSN=https://your_sentry_dsn@sentry.io/your_project_id
LOG_LEVEL=debug
